{
  "name": "logos-rx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:ci": "tsx scripts/audit-gate.ts",
    "lh": "npm run build && npx --yes @lhci/cli@latest autorun",
    "schema:check": "tsx scripts/validate-schema.ts",
    "schema:check:ci": "npm run build && tsx scripts/validate-schema.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "tsx scripts/db-push.ts",
    "db:studio": "drizzle-kit studio",
    "db:test": "tsx src/lib/db/test-connection.ts",
    "db:setup": "tsx src/lib/db/setup.ts",
    "db:seed-partners": "tsx scripts/seed-partners.ts",
    "db:seed-catalog": "tsx scripts/seed-catalog.ts",
    "catalog:upload": "tsx scripts/upload-catalog.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "^2.44.4",
    "@aws-sdk/client-sesv2": "^3.1057.0",
    "@aws-sdk/rds-signer": "^3.1019.0",
    "@clerk/nextjs": "^7.0.7",
    "@radix-ui/react-dialog": "^1.1.15",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.3.2",
    "@vercel/functions": "^3.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "next": "16.2.9",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
