    "db:studio": "drizzle-kit studio",
    "db:test": "tsx src/lib/db/test-connection.ts",
    "db:setup": "tsx src/lib/db/setup.ts"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1019.0",
