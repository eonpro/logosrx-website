    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/nextjs": "^10.53.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.3.2",
    "@vercel/functions": "^3.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
